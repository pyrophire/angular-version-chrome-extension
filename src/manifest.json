{
    "manifest_version": 3,
    "name": "Phire Angular Version Inspector",
    "version": "1.0.0",
    "description": "Inspects the web page for the Angular version.",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon48.png"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}